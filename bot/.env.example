BOT_TOKEN=your_telegram_bot_token
SUPABASE_URL=https://your-project.supabase.co
# Для саморегистрации по /start без миграции в Supabase — используйте service_role (Settings → API).
# anon-ключ потребует применения миграции 003_allow_insert_players.sql.
SUPABASE_KEY=your_service_role_or_anon_key
ADMIN_TELEGRAM_ID=123456789
WEBAPP_URL=https://yourusername.github.io/tennis-league

# Таймаут запросов к Telegram API в секундах (по умолчанию 120; полезно на Koyeb при долгом ответе сети)
# TELEGRAM_REQUEST_TIMEOUT=120

# Мгновенное уведомление сопернику в Telegram (опционально)
# NOTIFY_LISTEN_PORT=8765
# NOTIFY_SECRET=shared-secret-with-api
