# Supabase (same as bot)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-role-key

# CORS: через запятую список доверенных origin'ов (фронт, Mini App).
# Локальная разработка: http://localhost:5173. Продакшен: URL фронта (GitHub Pages или свой домен).
# CORS_ORIGINS=http://localhost:5173,https://your-username.github.io

# Optional: require X-API-Key header for all requests (leave empty to disable)
# API_KEY=your-secret-api-key

# Мгновенное уведомление сопернику (опционально): URL бота + секрет
# BOT_NOTIFY_URL=http://localhost:8765
# NOTIFY_SECRET=shared-secret-with-bot
